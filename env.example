# Copy to ~/.config/corridor-canary/env and fill in values.
# chmod 600 that file. Never commit it.

# Where Sage publishes ntfy — same URL Sage uses in ~/.sage_config.json.
NTFY_SERVER=https://ntfy.sh

# A NEW topic just for you. DO NOT reuse Sage's family topic.
# On ntfy.sh the topic name IS the access control — make it long and unguessable.
# Suggestion: canary-corridor-<8 random chars>   e.g. canary-corridor-9f3k2xq7
NTFY_TOPIC=canary-corridor-CHANGEME

# OPTIONAL: bearer token. Leave blank for ntfy.sh free tier (not supported there).
# Only fill in if you later move to ntfy Pro or self-hosted with auth.
NTFY_TOKEN=

# Optional tuning
NTFY_PRIORITY=default
NTFY_TAGS=rotating_light,child
CANARY_UA=corridor-canary/1.0 (OSINT; contact: britta@ohgollybritta.com)
CANARY_LOG_LEVEL=INFO
